{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "Node16",
    "moduleResolution": "node16",
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "paths": {
      "@pages/*": ["./pages/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@test-data/*": ["./test-data/*"]
    }
  },
  "include": ["fixtures/**/*.ts", "pages/**/*.ts", "tests/**/*.ts", "*.ts"],
  "exclude": ["node_modules", "test-results", "playwright-report"]
}
